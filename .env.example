# === Supabase (public, safe to expose) ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# === Supabase (server-only, required for security-sensitive routes) ===
SUPABASE_SERVICE_ROLE_KEY=

# === Encryption (auto-generated on deploy, or run: openssl rand -base64 32) ===
ENCRYPTION_KEY=

# === Room Sub-App security settings ===
# Configure ROOM_TOKEN_SECRET / ROOM_REALTIME_JWT_PRIVATE_KEY / ROOM_REALTIME_JWT_KID
# in Dashboard -> Sub-Apps -> Room, not in deployment env.

# === App URL (for pg_cron callbacks — must be publicly reachable from Supabase) ===
# Production: https://your-app.vercel.app
# Local dev: use ngrok/cloudflare tunnel URL (localhost won't work — pg_cron runs on Supabase servers)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# === Cron Secret (protects /api/worker/remind from unauthorized calls) ===
CRON_SECRET=
